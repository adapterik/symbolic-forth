    \ hello

: header1

 SYM header1 line-context !

  " <h1>" PRINT / this is a comment too...

  ( echo rest of line to output )

  VARIABLE blah

  CHAR

  " </h1>" PRINT

  null line-context !
;


null VARIABLE mode

: set-mode
  mode !
;

: start-list-mode
  mode @SYM list
;

: ordered-list-start
 SYM ordered-list mode @ EQ NOT
  IF
    " = <ol>" PRINTLN
   SYM ordered-list mode !
  THEN
;

: ordered-list-end
 SYM ordered-list mode @ EQ
  IF
    " = </ol>" PRINTLN
    null mode !
  THEN
;

: token-to-tag

  DUP " #"    S= IF DROP " </H1>" " <H1>" EXIT THEN
  DUP " ##"   S= IF DROP " </H2>" " <H2>" EXIT THEN
  DUP " ###"  S= IF DROP " </H3>" " <H3>" EXIT THEN
  DUP " ####" S= IF DROP " </H4>" " <H4>" EXIT THEN

  \  " here?" println
  \  " why not? " println
  \  " size: " print dup string::length println
  \  " string: " print dup println
  \  " matches +:" print dup " +" S= println

  DUP " +" S= IF DROP " </P>" " <P>" EXIT THEN

  ( todo - a regex of sorts so we can detect any number and dot )
  ( LEFT OFF HERE - we need to deal with "modes" - ordered list, unordered
    list, table ... is that it?)

  DUP " 1." S= IF DROP " </li>" " <li>" EXIT THEN
  DUP " 2." S= IF DROP " </li>" " <li>" EXIT THEN
  DUP " 3." S= IF DROP " </li>" " <li>" EXIT THEN
  DUP " 4." S= IF DROP " </li>" " <li>" EXIT THEN
  DUP " 5." S= IF DROP " </li>" " <li>" EXIT THEN


  DUP " -" S= IF DROP " </li>" " <li>" EXIT THEN
  DUP " *" S= IF DROP " </li>" " <li>"  EXIT THEN

  ( default condition - a paragraph )
  DROP
  " </p>" " <p>"
;

10 stack::create VARIABLE mode-stack

null VARIABLE mode

: emit-h1-tag
  " <H1>" PRINT
  PRINT ( contents )
  " </H1>" PRINTLN
;

: emit-h2-tag
  " <H2>" PRINT
  PRINT ( contents )
  " </H2>" PRINTLN
;

: emit-h3-tag
  " <H3>" PRINT
  PRINT ( contents )
  " </H3>" PRINTLN
;

: emit-h4-tag
  " <H4>" PRINT
  PRINT ( contents )
  " </H4>" PRINTLN
;

: emit-p-tag
  " <P>" PRINT
  PRINT ( contents )
  " </P>" PRINTLN
;

: emit-li-tag
  " <LI>" PRINT
  PRINT
  " </LI>" PRINTLN
;

\  : emit-ul-li-tag
\    " <LI>" PRINT
\    PRINT
\    " </LI>" PRINTLN
\  ;

: begin-numbered-list-mode
  " <OL>" PRINTLN
 SYM numbered-list mode-stack @ stack::push
;

: end-numbered-list-mode
  " </OL>" PRINTLN
  mode-stack @ stack::pop DROP
;


: begin-list-mode
  " <UL>" PRINTLN
  mode-stack @ stack::pushSYM list
;

: end-list-mode
  " </UL>" PRINTLN
  mode-stack @ stack::pop DROP
;

( responsible for returning the processing word corresponding to the given
  start-of-line token.
  Note that this is context-sensitive - it honors the currerent mode.
  This simplifies processing of lists and tables, and allows us to use, for
  instance, a number at the beginning of a regular line without unexpectedly switching into list mode.)
: token-to-word
    mode-stack @ stack::peek

    BEGIN

      DUP SYM normal EQ IF
        SWAP
        DUP " #"    S= IF SYM emit-h1-tag BREAK THEN
        DUP " ##"   S= IF SYM emit-h2-tag BREAK THEN
        DUP " ###"  S= IF SYM emit-h3-tag BREAK THEN
        DUP " ####" S= IF SYM emit-h4-tag BREAK THEN
        DUP " +" S= IF SYM emit-p-tag BREAK THEN
        DUP " @list" S= IF SYM begin-list-mode BREAK THEN
        DUP " @numbered-list" S= IFSYM begin-numbered-list-mode BREAK THEN
        DUP " @end"  S= IF SYM end-mode BREAK THEN

        ( default is a paragraph )
        null

      ELSE
        DUP SYM list EQ IF
          SWAP
          DUP " -" S= IF SYM emit-li-tag BREAK THEN
          DUP " *" S= IF SYM emit-li-tag  BREAK THEN
          DUP " @end" S= IF SYM end-list-mode BREAK THEN
        ELSE
          DUP SYM numbered-list EQ IF
            SWAP
            DUP " 1." S= IF SYM emit-li-tag BREAK THEN
            DUP " 2." S= IF SYM emit-li-tag BREAK THEN
            DUP " 3." S= IF SYM emit-li-tag BREAK THEN
            DUP " 4." S= IF SYM emit-li-tag BREAK THEN
            DUP " 5." S= IF SYM emit-li-tag BREAK THEN
          DUP " @end" S= IF SYM end-numbered-list-mode BREAK THEN
          THEN
        THEN
      THEN

    CATCH

    SWAP
    DROP
;


( ---------------------------------- )
( Main program )
( ---------------------------------- )


( Arguments
  All arguments to sf.js are put on the stack in the same order they are
  provided in the command line. That is, argument 1 is put on the stack
  first, so becomes the deepest stack element, and so forth, with the last
  argument being on the top of the stack.
  For convenience, we put them into variables.
)

( not that since all command line arguments are available on this stack
  this has the effect of putting the first argument into the input_file
  variable )

VAR input-file

" Converting file: " PRINT input-file @ PRINTLN

( Open the input file and save the file handle for later. )
input-file @ FILE::OPEN VARIABLE file-handle

0 VARIABLE items

SYM ormal mode-stack @ STACK::PUSH

BEGIN
  ( get the first word in the file and save it )
  file-handle @ FILE::GET-WORD VARIABLE the-word

  ( If we attempt to get a word and that would take us past the end of the
    file, null is put on the stack instead of the word )
  the-word @ TYPEOF " null" S= IF
    " We are done!" PRINTLN
    EXIT
  THEN

  file_handle @ FILE::GET-LINE VARIABLE the-line

  the-word @ token-to-word VARIABLE token-word

  token-word @ typeof " null" S= IF
    A[ " <P>" the-word @ "  " the-line @ " </P>" ] PRINTLN
  ELSE
    the-line @ token-word @ EXEC
  THEN

  " " PRINTLN

  items INC!

REPEAT

" Done!" PRINTLN

file_handle @ file::close
