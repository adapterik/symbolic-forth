" ------------------------" PRINTLN
" Welcome to Symbolc FORTH" PRINTLN
" ------------------------" PRINTLN

M{ SYM key1 123 SYM key2 " foo" } VARIABLE map

" map created" PRINTLN

" get key1: " PRINT
SYM key1 map @ MAP::GET PRINTLN

" get key2: " PRINT
SYM key2 map @ MAP::GET PRINTLN

SYM hello SYM key3 map @ MAP::SET
" get key3: " PRINT
SYM key3 map @ MAP::GET PRINTLN


