M{ ~key1 123 ~key2 " foo" } VARIABLE map

" map created" PRINTLN

" get key1: " PRINT
~key1 map @ MAP::GET PRINTLN

" get key2: " PRINT
~key2 map @ MAP::GET PRINTLN

~hello ~key3 map @ MAP::SET
" get key3: " PRINT
~key3 map @ MAP::GET PRINTLN


