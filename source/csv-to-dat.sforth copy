: row-to-dat ( csv-row/array -- dat-row/array )
  L:> row

  0 ARRAY::NARRAY L:> dat

  L@ row ARRAY::LENGTH 0 DO
    \ remember, the index element is on top of stack :)
    L@ row A@ DUP STRING::LENGTH L@ dat ARRAY::APPEND
    L@ dat ARRAY::APPEND
  LOOP

  L@ dat
;

: print-datx ( dat-row/array -- )
  DUP L:> dat-row
  ARRAY::LENGTH L:> len
  " Length? " PRINT L@ len PRINTLN
  0 L:> pos

  BEGIN
    L@ len L@ pos = IF BREAK THEN

    L@ pos L@ dat-row A@ TO-STRING PRINT
    "  " PRINT

    L+! pos
  REPEAT
;

: print-dat ( dat-row/array -- )
  DUP L:> row
  ARRAY::LENGTH 0 DO
    L@ row A@ TO-STRING PRINT
    "  " PRINT
  LOOP
;

